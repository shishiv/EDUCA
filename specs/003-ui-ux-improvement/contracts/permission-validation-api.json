{
  "openapi": "3.0.0",
  "info": {
    "title": "Configuration Security Validation API",
    "version": "1.0.0",
    "description": "API specification for validating Claude Code configuration security and permissions"
  },
  "paths": {
    "/permissions/validate": {
      "post": {
        "summary": "Validate permissions configuration",
        "description": "Validates permission configuration for security compliance",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PermissionValidationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validation completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/permissions/deduplicate": {
      "post": {
        "summary": "Remove duplicate permissions",
        "description": "Identifies and removes duplicate permissions while maintaining functionality",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeduplicationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Deduplication completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeduplicationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/permissions/audit": {
      "get": {
        "summary": "Generate security audit report",
        "description": "Generates comprehensive security audit report for current configuration",
        "responses": {
          "200": {
            "description": "Audit report generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditReport"
                }
              }
            }
          }
        }
      }
    },
    "/mcp-tools/validate": {
      "post": {
        "summary": "Validate MCP tool security",
        "description": "Validates MCP tool configuration for security compliance",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MCPValidationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "MCP validation completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/documentation/validate": {
      "post": {
        "summary": "Validate documentation completeness",
        "description": "Validates documentation for completeness and security context",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentationValidationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Documentation validation completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PermissionValidationRequest": {
        "type": "object",
        "required": ["config_path"],
        "properties": {
          "config_path": {
            "type": "string",
            "description": "Path to settings.local.json file"
          },
          "validation_rules": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Specific validation rules to apply"
          },
          "educational_context": {
            "type": "boolean",
            "description": "Apply Brazilian educational compliance rules"
          }
        }
      },
      "ValidationResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["valid", "needs_attention", "non_compliant"]
          },
          "issues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationIssue"
            }
          },
          "recommendations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metrics": {
            "$ref": "#/components/schemas/ValidationMetrics"
          }
        }
      },
      "ValidationIssue": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["duplicate", "overly_broad", "missing_security", "compliance_gap"]
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "error", "critical"]
          },
          "description": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          }
        }
      },
      "ValidationMetrics": {
        "type": "object",
        "properties": {
          "total_permissions": {
            "type": "integer"
          },
          "duplicate_count": {
            "type": "integer"
          },
          "high_risk_count": {
            "type": "integer"
          },
          "compliance_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        }
      },
      "DeduplicationRequest": {
        "type": "object",
        "required": ["config_path"],
        "properties": {
          "config_path": {
            "type": "string"
          },
          "dry_run": {
            "type": "boolean",
            "default": true
          },
          "preserve_functionality": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "DeduplicationResponse": {
        "type": "object",
        "properties": {
          "removed_count": {
            "type": "integer"
          },
          "removed_permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "AuditReport": {
        "type": "object",
        "properties": {
          "summary": {
            "$ref": "#/components/schemas/AuditSummary"
          },
          "permission_analysis": {
            "$ref": "#/components/schemas/PermissionAnalysis"
          },
          "mcp_analysis": {
            "$ref": "#/components/schemas/MCPAnalysis"
          },
          "documentation_analysis": {
            "$ref": "#/components/schemas/DocumentationAnalysis"
          },
          "recommendations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuditRecommendation"
            }
          }
        }
      },
      "AuditSummary": {
        "type": "object",
        "properties": {
          "overall_risk_level": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "compliance_status": {
            "type": "string",
            "enum": ["compliant", "partial", "non_compliant"]
          },
          "total_issues": {
            "type": "integer"
          },
          "critical_issues": {
            "type": "integer"
          }
        }
      },
      "PermissionAnalysis": {
        "type": "object",
        "properties": {
          "total_permissions": {
            "type": "integer"
          },
          "duplicate_permissions": {
            "type": "integer"
          },
          "overly_broad_permissions": {
            "type": "integer"
          },
          "high_risk_permissions": {
            "type": "integer"
          },
          "permission_categories": {
            "type": "object",
            "additionalProperties": {
              "type": "integer"
            }
          }
        }
      },
      "MCPAnalysis": {
        "type": "object",
        "properties": {
          "enabled_servers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "high_risk_tools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "undocumented_tools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "security_gaps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "DocumentationAnalysis": {
        "type": "object",
        "properties": {
          "missing_sections": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outdated_sections": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "security_context_gaps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "educational_compliance_coverage": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        }
      },
      "AuditRecommendation": {
        "type": "object",
        "properties": {
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "category": {
            "type": "string",
            "enum": ["security", "documentation", "compliance", "performance"]
          },
          "description": {
            "type": "string"
          },
          "action_items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "estimated_effort": {
            "type": "string"
          }
        }
      },
      "MCPValidationRequest": {
        "type": "object",
        "required": ["mcp_servers"],
        "properties": {
          "mcp_servers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "validate_security_context": {
            "type": "boolean",
            "default": true
          },
          "educational_compliance": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "DocumentationValidationRequest": {
        "type": "object",
        "required": ["documentation_paths"],
        "properties": {
          "documentation_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "validate_security_context": {
            "type": "boolean",
            "default": true
          },
          "check_completeness": {
            "type": "boolean",
            "default": true
          },
          "educational_terminology": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "object"
          }
        }
      }
    }
  }
}