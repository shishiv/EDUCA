{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Configuration Security Validation Schema",
  "description": "Schema for validating Claude Code configuration security patterns",
  "type": "object",
  "definitions": {
    "PermissionValidationConfig": {
      "type": "object",
      "properties": {
        "rules": {
          "type": "object",
          "properties": {
            "duplicate_detection": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "severity": {
                  "type": "string",
                  "enum": ["warning", "error", "critical"],
                  "default": "error"
                }
              }
            },
            "scope_validation": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "max_directory_depth": {
                  "type": "integer",
                  "minimum": 1,
                  "default": 3
                },
                "forbidden_patterns": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": ["/**/*", "/C:\\**", "/**/.*"]
                }
              }
            },
            "risk_assessment": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "high_risk_threshold": {
                  "type": "integer",
                  "minimum": 1,
                  "default": 10
                },
                "categories": {
                  "type": "object",
                  "properties": {
                    "read_only": {
                      "type": "string",
                      "enum": ["low", "medium", "high"],
                      "default": "low"
                    },
                    "database": {
                      "type": "string",
                      "enum": ["low", "medium", "high"],
                      "default": "high"
                    },
                    "browser": {
                      "type": "string",
                      "enum": ["low", "medium", "high"],
                      "default": "medium"
                    },
                    "git_operations": {
                      "type": "string",
                      "enum": ["low", "medium", "high"],
                      "default": "medium"
                    },
                    "file_system": {
                      "type": "string",
                      "enum": ["low", "medium", "high"],
                      "default": "medium"
                    }
                  }
                }
              }
            },
            "educational_compliance": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "brazilian_standards": {
                  "type": "boolean",
                  "default": true
                },
                "multi_school_isolation": {
                  "type": "boolean",
                  "default": true
                },
                "audit_requirements": {
                  "type": "boolean",
                  "default": true
                }
              }
            }
          }
        }
      }
    },
    "MCPSecurityConfig": {
      "type": "object",
      "properties": {
        "server_configurations": {
          "type": "object",
          "patternProperties": {
            "^[a-zA-Z0-9_-]+$": {
              "$ref": "#/definitions/MCPServerConfig"
            }
          }
        },
        "global_security": {
          "type": "object",
          "properties": {
            "require_documentation": {
              "type": "boolean",
              "default": true
            },
            "audit_tool_usage": {
              "type": "boolean",
              "default": true
            },
            "educational_data_protection": {
              "type": "boolean",
              "default": true
            }
          }
        }
      }
    },
    "MCPServerConfig": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/MCPCapability"
          }
        },
        "security_context": {
          "$ref": "#/definitions/SecurityContext"
        },
        "documentation_required": {
          "type": "boolean",
          "default": true
        },
        "educational_approved": {
          "type": "boolean"
        }
      },
      "required": ["name", "risk_level", "security_context"]
    },
    "MCPCapability": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "requires_validation": {
          "type": "boolean"
        },
        "educational_use_cases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "security_notes": {
          "type": "string"
        }
      },
      "required": ["name", "risk_level"]
    },
    "SecurityContext": {
      "type": "object",
      "properties": {
        "data_access_level": {
          "type": "string",
          "enum": ["read_only", "limited_write", "full_access", "admin_level"]
        },
        "authentication_required": {
          "type": "boolean"
        },
        "rate_limiting": {
          "$ref": "#/definitions/RateLimiting"
        },
        "audit_logging": {
          "type": "boolean"
        },
        "educational_compliance": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ComplianceRequirement"
          }
        }
      },
      "required": ["data_access_level", "authentication_required", "audit_logging"]
    },
    "RateLimiting": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "requests_per_minute": {
          "type": "integer",
          "minimum": 1
        },
        "burst_limit": {
          "type": "integer",
          "minimum": 1
        },
        "educational_exemptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ComplianceRequirement": {
      "type": "object",
      "properties": {
        "regulation": {
          "type": "string",
          "enum": ["LGPD", "LBI", "educational_ministry", "municipal_policy"]
        },
        "requirement": {
          "type": "string"
        },
        "implementation_status": {
          "type": "string",
          "enum": ["compliant", "partial", "non_compliant", "not_applicable"]
        },
        "documentation_link": {
          "type": "string",
          "format": "uri"
        },
        "notes": {
          "type": "string"
        }
      },
      "required": ["regulation", "requirement", "implementation_status"]
    },
    "DocumentationValidationConfig": {
      "type": "object",
      "properties": {
        "sections": {
          "type": "object",
          "properties": {
            "required_sections": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [
                "MCP Security Guidelines",
                "Educational Compliance",
                "Development Commands",
                "Quick Reference"
              ]
            },
            "security_context_required": {
              "type": "boolean",
              "default": true
            },
            "educational_terminology": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "validation_rules": {
          "type": "object",
          "properties": {
            "link_validation": {
              "type": "boolean",
              "default": true
            },
            "command_validation": {
              "type": "boolean",
              "default": true
            },
            "security_warning_coverage": {
              "type": "boolean",
              "default": true
            },
            "portuguese_terminology": {
              "type": "boolean",
              "default": true
            }
          }
        }
      }
    },
    "ValidationReport": {
      "type": "object",
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "configuration_file": {
          "type": "string"
        },
        "validation_results": {
          "type": "object",
          "properties": {
            "permission_validation": {
              "$ref": "#/definitions/PermissionValidationResult"
            },
            "mcp_validation": {
              "$ref": "#/definitions/MCPValidationResult"
            },
            "documentation_validation": {
              "$ref": "#/definitions/DocumentationValidationResult"
            }
          }
        },
        "overall_status": {
          "type": "string",
          "enum": ["valid", "needs_attention", "non_compliant"]
        },
        "risk_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "recommendations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Recommendation"
          }
        }
      },
      "required": ["timestamp", "configuration_file", "overall_status"]
    },
    "PermissionValidationResult": {
      "type": "object",
      "properties": {
        "total_permissions": {
          "type": "integer"
        },
        "duplicate_permissions": {
          "type": "integer"
        },
        "overly_broad_permissions": {
          "type": "integer"
        },
        "high_risk_permissions": {
          "type": "integer"
        },
        "issues": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ValidationIssue"
          }
        },
        "compliance_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "MCPValidationResult": {
      "type": "object",
      "properties": {
        "enabled_servers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "security_gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "undocumented_tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "educational_compliance_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "DocumentationValidationResult": {
      "type": "object",
      "properties": {
        "missing_sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "security_coverage_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "educational_terminology_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "link_validation_passed": {
          "type": "boolean"
        }
      }
    },
    "ValidationIssue": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["duplicate", "overly_broad", "missing_security", "compliance_gap", "documentation_missing"]
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error", "critical"]
        },
        "description": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "recommendation": {
          "type": "string"
        },
        "educational_impact": {
          "type": "boolean"
        }
      },
      "required": ["type", "severity", "description"]
    },
    "Recommendation": {
      "type": "object",
      "properties": {
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "category": {
          "type": "string",
          "enum": ["security", "documentation", "compliance", "performance"]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "action_items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "estimated_effort": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "educational_benefit": {
          "type": "string"
        }
      },
      "required": ["priority", "category", "title", "description"]
    }
  },
  "properties": {
    "validation_config": {
      "$ref": "#/definitions/PermissionValidationConfig"
    },
    "mcp_security_config": {
      "$ref": "#/definitions/MCPSecurityConfig"
    },
    "documentation_config": {
      "$ref": "#/definitions/DocumentationValidationConfig"
    }
  },
  "additionalProperties": false
}