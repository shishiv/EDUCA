# ============================================================================
# EDUCA - Sistema de Gestão Escolar Municipal
# Environment Variables Template
# ============================================================================
# Copy this file to .env.local and fill in the values
# cp .env.local.example .env.local
# ============================================================================

# =========================
# SUPABASE CONFIGURATION
# =========================

# Public Supabase URL (safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public Anon Key (safe for client-side, respects RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (SERVER-SIDE ONLY - bypasses RLS)
# Required for: seed scripts, admin operations, auth.admin methods
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =========================
# APPLICATION SETTINGS
# =========================

# Environment: development | staging | production
NODE_ENV=development

# =========================
# OPTIONAL - Analytics
# =========================

# PostHog (currently disabled due to Turbopack HMR bug)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================================================
# PRODUCTION VALUES (for reference - get from Supabase dashboard)
# ============================================================================
# Project URL: Settings > Project Settings > API > Project URL
# Anon Key: Settings > Project Settings > API > anon public
# Service Role Key: Settings > Project Settings > API > service_role (secret)
# ============================================================================

# =========================
# MUNICIPAL IDENTITY
# =========================

# Name of the municipality
NEXT_PUBLIC_MUNICIPAL_NAME=Nome do Município

# Name of the education secretariat
NEXT_PUBLIC_SECRETARIA_NAME=Secretaria Municipal de Educação

# State abbreviation (UF)
NEXT_PUBLIC_MUNICIPAL_STATE=UF

# Support contact phone
NEXT_PUBLIC_CONTACT_PHONE=

# DPO (Data Protection Officer) e-mail
NEXT_PUBLIC_DPO_EMAIL=

# DPO address (for privacy policy)
NEXT_PUBLIC_DPO_ADDRESS=
